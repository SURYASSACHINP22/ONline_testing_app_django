DJANGO_SECRET_KEY=change-this-to-a-strong-random-secret-key-at-least-32-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Cookie / transport security
JWT_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# HSTS (1 year recommended)
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Optional cookie policies
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# API throttling
DRF_THROTTLE_ANON=50/hour
DRF_THROTTLE_USER=500/hour
DRF_THROTTLE_LOGIN=10/min
DRF_THROTTLE_REGISTER=5/min
DRF_THROTTLE_TOKEN=10/min
